DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# true = local manage.py without Docker. false = Docker production stack (default in .env for compose).
DEV_USE_SQLITE=false

# Host ports (random defaults to avoid clashes with other local services)
POSTGRES_HOST_PORT=47291
REDIS_HOST_PORT=58163
MINIO_API_HOST_PORT=38472
MINIO_CONSOLE_HOST_PORT=41908
WEB_PORT=52841
FRONTEND_PORT=61294

DATABASE_URL=postgres://fleet:fleet@localhost:47291/fleet_manager
REDIS_URL=redis://localhost:58163/0

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=fleet-manager
AWS_S3_ENDPOINT_URL=http://localhost:38472
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false

CELERY_HEARTBEAT_FLUSH_SECONDS=60
OTA_SIGNED_URL_EXPIRY_SECONDS=3600
