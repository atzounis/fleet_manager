DEBUG=true
SECRET_KEY=change-me-in-production
# Include your Mac LAN IP so ESP32 can reach the API (e.g. 192.168.68.108)
ALLOWED_HOSTS=localhost,127.0.0.1,web,192.168.68.108

# true = local manage.py without Docker. false = Docker production stack (default in .env for compose).
DEV_USE_SQLITE=false

# Host ports (random defaults to avoid clashes with other local services)
POSTGRES_HOST_PORT=47291
REDIS_HOST_PORT=58163
MINIO_API_HOST_PORT=38472
MINIO_CONSOLE_HOST_PORT=41908
WEB_PORT=52841
FRONTEND_PORT=61294

DATABASE_URL=postgres://fleet:fleet@localhost:47291/fleet_manager
REDIS_URL=redis://localhost:58163/0

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=fleet-manager
AWS_S3_ENDPOINT_URL=http://localhost:38472
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false

CELERY_HEARTBEAT_FLUSH_SECONDS=60
# Device online/offline rule:
# offline when no heartbeat for EXPECTED_INTERVAL * MISSED_ITERATIONS seconds.
HEARTBEAT_EXPECTED_INTERVAL_SECONDS=60
HEARTBEAT_MISSED_ITERATIONS=3

# Dashboard threshold lines (red dashed) for telemetry charts.
THRESHOLD_HEAP_FREE_BYTES_MIN=50000
THRESHOLD_WIFI_RSSI_DBM_MIN=-75
THRESHOLD_BATTERY_VOLTAGE_MV_MIN=3600
THRESHOLD_CPU_TEMPERATURE_C_MAX=75
OTA_SIGNED_URL_EXPIRY_SECONDS=3600
