# Server-side .env for Fleet Manager on Hetzner (copy to /root/fleet_manager/.env).
DEBUG=false
SECRET_KEY=change-me-generate-a-long-random-string
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=change-me-set-your-password
ALLOWED_HOSTS=YOUR_HETZNER_SERVER_IP,localhost,127.0.0.1
CORS_EXTRA_ORIGINS=http://YOUR_HETZNER_SERVER_IP:8993
CSRF_EXTRA_ORIGINS=http://YOUR_HETZNER_SERVER_IP:8993

DEV_USE_SQLITE=true
SQLITE_DB_PATH=/root/fleet_manager/data/db.sqlite3

# Public dashboard URL (nginx)
FLEET_PUBLIC_PORT=8993
# Internal Gunicorn (localhost only — not exposed to other apps)
FLEET_GUNICORN_PORT=8995

# Isolated Docker ports (redis/minio for this app only)
FLEET_REDIS_PORT=6380
FLEET_MINIO_API_PORT=9100
FLEET_MINIO_CONSOLE_PORT=9101

REDIS_URL=redis://127.0.0.1:6380/0

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=fleet-manager
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9100
AWS_S3_PUBLIC_ENDPOINT_URL=http://YOUR_HETZNER_SERVER_IP:9100
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false

GUNICORN_WORKERS=2
CELERY_HEARTBEAT_FLUSH_SECONDS=60
HEARTBEAT_EXPECTED_INTERVAL_SECONDS=60
HEARTBEAT_MISSED_ITERATIONS=3

THRESHOLD_HEAP_FREE_BYTES_MIN=50000
THRESHOLD_HEAP_FREE_BYTES_MIN_8266=35000
THRESHOLD_WIFI_RSSI_DBM_MIN=-75
THRESHOLD_BATTERY_VOLTAGE_MV_MIN=3600
THRESHOLD_CPU_TEMPERATURE_C_MAX=75
OTA_SIGNED_URL_EXPIRY_SECONDS=3600
OTA_UPLOAD_MAX_MB=32
