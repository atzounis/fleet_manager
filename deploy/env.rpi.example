# Copy to deploy/.env on the Raspberry Pi (deploy-rpi.sh does this on first run).
DEBUG=false
SECRET_KEY=change-me-generate-a-long-random-string
ALLOWED_HOSTS=192.168.2.200,localhost,127.0.0.1,web

DEV_USE_SQLITE=true
SQLITE_DB_PATH=/app/data/db.sqlite3

WEB_PORT=52841
FRONTEND_PORT=61294
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

REDIS_URL=redis://redis:6379/0

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=fleet-manager
AWS_S3_ENDPOINT_URL=http://minio:9000
# LAN address devices use to download OTA binaries (must match MINIO_API_HOST_PORT).
AWS_S3_PUBLIC_ENDPOINT_URL=http://192.168.2.200:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false

GUNICORN_WORKERS=2
CELERY_HEARTBEAT_FLUSH_SECONDS=60
HEARTBEAT_EXPECTED_INTERVAL_SECONDS=60
HEARTBEAT_MISSED_ITERATIONS=3

THRESHOLD_HEAP_FREE_BYTES_MIN=50000
THRESHOLD_HEAP_FREE_BYTES_MIN_8266=35000
THRESHOLD_WIFI_RSSI_DBM_MIN=-75
THRESHOLD_BATTERY_VOLTAGE_MV_MIN=3600
THRESHOLD_CPU_TEMPERATURE_C_MAX=75
OTA_SIGNED_URL_EXPIRY_SECONDS=3600
OTA_UPLOAD_MAX_MB=32
